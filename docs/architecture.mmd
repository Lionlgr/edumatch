flowchart TD
    Client["💻 curl / browser<br/>Host: edumatch.local"]

    subgraph minikube["Minikube cluster"]
        direction TB

        subgraph istio_sys["istio-system"]
            Gateway["🛡️ Istio Ingress Gateway<br/>(Envoy)"]
        end

        subgraph edumatch_ns["edumatch namespace — mTLS STRICT"]
            direction TB

            subgraph user_svc["user-service (2 replicas)"]
                UserApp["☕ Spring Boot<br/>JWT + REST"]
                UserSidecar["📦 Envoy sidecar"]
            end

            subgraph tutor_svc["tutor-service (2 replicas)"]
                TutorApp["☕ Spring Boot<br/>REST + gRPC :9090"]
                TutorSidecar["📦 Envoy sidecar"]
            end

            subgraph user_pg["user-postgres (StatefulSet)"]
                UserDB[("🐘 PostgreSQL 16")]
                UserPgSidecar["📦 Envoy sidecar"]
            end

            subgraph tutor_pg["tutor-postgres (StatefulSet)"]
                TutorDB[("🐘 PostgreSQL 16")]
                TutorPgSidecar["📦 Envoy sidecar"]
            end
        end
    end

    Client -- "HTTP /api/*" --> Gateway
    Gateway -- "mTLS<br/>/api/auth, /api/users → user-service" --> UserSidecar
    Gateway -- "mTLS<br/>/api/tutors → tutor-service" --> TutorSidecar
    UserSidecar --> UserApp
    TutorSidecar --> TutorApp
    UserApp -- "mTLS gRPC :9090" --> TutorSidecar
    UserApp -- "mTLS JDBC" --> UserPgSidecar
    UserPgSidecar --> UserDB
    TutorApp -- "mTLS JDBC" --> TutorPgSidecar
    TutorPgSidecar --> TutorDB

    classDef sidecar fill:#e1f5ff,stroke:#0288d1,color:#01579b
    classDef app fill:#fff3e0,stroke:#f57c00,color:#e65100
    classDef db fill:#f3e5f5,stroke:#7b1fa2,color:#4a148c
    classDef gw fill:#e8f5e9,stroke:#2e7d32,color:#1b5e20

    class UserSidecar,TutorSidecar,UserPgSidecar,TutorPgSidecar sidecar
    class UserApp,TutorApp app
    class UserDB,TutorDB db
    class Gateway gw
